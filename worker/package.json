{
  "name": "@calebsargeant/release-runner",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm test && npx wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
